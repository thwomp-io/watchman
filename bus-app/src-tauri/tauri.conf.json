{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Watchman",
  "version": "0.7.0",
  "identifier": "io.thwomp.watchman.bus",
  "build": {
    "beforeDevCommand": "node scripts/stage-engine.mjs && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node scripts/stage-engine.mjs && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Watchman",
        "width": 920,
        "height": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../samples/packs": "packs",
      "engine": "engine"
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer-assets/nsis-header.bmp",
        "sidebarImage": "installer-assets/nsis-sidebar.bmp"
      },
      "wix": {
        "bannerPath": "installer-assets/wix-banner.bmp",
        "dialogImagePath": "installer-assets/wix-dialog.bmp"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM4M0RBOTczM0QxMEM1NApSV1JVRE5Femw5cURBeThBOEVIUlA4RHlrbDBaNExuL3BCZTQ0T053MzhUUHliN1BocFNXZHVNKwo="
    }
  }
}